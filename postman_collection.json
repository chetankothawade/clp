    {
      "name": "Loyalty Program APIs",
      "description": "Use the seeded login requests first. Admin requests use admin_token; customer requests use customer_token.",
      "item": [
        {
          "name": "Authentication - Seeded Accounts",
          "item": [
            {
              "name": "POST Login - Admin Seeder",
              "request": {
                "method": "POST",
                "auth": { "type": "noauth" },
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"admin@yopmail.com\",\n  \"password\": \"Admin@123\"\n}"
                },
                "url": "{{base_url}}/api/v1/login"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const response = pm.response.json();",
                      "pm.collectionVariables.set('admin_token', response.data.token);"
                    ]
                  }
                }
              ]
            },
            {
              "name": "POST Login - Customer Seeder",
              "request": {
                "method": "POST",
                "auth": { "type": "noauth" },
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"user@yopmail.com\",\n  \"password\": \"User@123\"\n}"
                },
                "url": "{{base_url}}/api/v1/login"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const response = pm.response.json();",
                      "pm.collectionVariables.set('customer_token', response.data.token);"
                    ]
                  }
                }
              ]
            }
          ]
        },
        {
          "name": "Admin - Products",
          "item": [
            {
              "name": "POST Create Product",
              "request": {
                "method": "POST",
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    {
                      "key": "token",
                      "value": "{{admin_token}}",
                      "type": "string"
                    }
                  ]
                },
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Postman Demo Product\",\n  \"sku\": \"POSTMAN-DEMO-001\",\n  \"price\": 999.00,\n  \"description\": \"Created from Postman\",\n  \"loyalty_points\": 100,\n  \"category_id\": {{category_id}}\n}"
                },
                "url": "{{base_url}}/api/v1/products"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const response = pm.response.json();",
                      "pm.collectionVariables.set('product_uuid', response.data.product.uuid);"
                    ]
                  }
                }
              ]
            },
            {
              "name": "GET List Products",
              "request": {
                "method": "GET",
