                  "raw": "{\n  \"name\": \"Postman Gift Voucher\",\n  \"description\": \"Created from Postman\",\n  \"reward_type\": \"voucher\",\n  \"points_required\": 100,\n  \"stock\": 10\n}"
                },
                "url": "{{base_url}}/api/v1/rewards"
